aipw_policy_value <- function(policy, mu0, ps, X, A, Y){
yA <- mu0(a=A,x=X)
y_policy <- mu0(a=policy,x=X)
corrected <- y_policy + ((A*policy + (1-A)*(1-policy))/(ps(a=A,x=X)))*(Y-yA)
aipw_value <- mean(corrected)
return(aipw_value)
}
aipw_constraint_value <- function(policy, nu0, ps, X, A, Xi){
XiA <- nu0(a=A,x=X)
Xi1 <- nu0(a=rep(1,nrow(X)),x=X)
Xi0 <- nu0(a=rep(0,nrow(X)),x=X)
term <- policy * (Xi1-Xi0) - alpha.tolerance
corrected <- term + ((2*A-1)/(ps(a=A,x=X)))*policy*(Xi-XiA)
aipw_value <- mean(corrected)
return(aipw_value)
}
