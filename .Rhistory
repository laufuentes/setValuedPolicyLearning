XiA <- nu0(a=A,x=X)
Xi1 <- nu0(a=rep(1,nrow(X)),x=X)
Xi0 <- nu0(a=rep(0,nrow(X)),x=X)
term <- policy * (Xi1-Xi0) - alpha.tolerance
corrected <- term + ((2*A-1)/(ps(a=A,x=X)))*policy*(Xi-XiA)
aipw_value <- mean(corrected)
return(c(mean(term),aipw_value))
}
PV_proba_pluc <- aipw_policy_value(policy=proba_PLUC_test,
mu0 = mu0_test_non_norm, ps=ps_test_non_norm,
X = covariates_test, A = A_test, Y = Y_non_test)
PV_proba_pluc0 <- aipw_policy_value(policy=proba_PLUC0_test,
mu0 = mu0_test_non_norm, ps=ps_test_non_norm,
X = covariates_test, A = A_test, Y = Y_non_test)
PV_decision_pluc <- aipw_policy_value(policy=decision_PLUC_test,
mu0 = mu0_test_non_norm, ps=ps_test_non_norm,
X = covariates_test, A = A_test, Y = Y_non_test)
PV_proba_naive <- aipw_policy_value(policy=proba_Naive_test,
mu0 = mu0_test_non_norm, ps=ps_test_non_norm,
X = covariates_test, A = A_test, Y = Y_non_test)
PV_proba_naive0 <- aipw_policy_value(policy=proba_Naive0_test,
mu0 = mu0_test_non_norm, ps=ps_test_non_norm,
X = covariates_test, A = A_test, Y = Y_non_test)
PV_decision_naive <- aipw_policy_value(policy=decision_Naive_test,
mu0 = mu0_test_non_norm, ps=ps_test_non_norm,
X = covariates_test, A = A_test, Y = Y_non_test)
PV_decision_baseline <- aipw_policy_value(policy=baseline_test,
mu0 = mu0_test_non_norm, ps=ps_test_non_norm,
X = covariates_test, A = A_test, Y = Y_non_test)
PV_decision_surrogate1 <- aipw_policy_value(policy=surrogate1,
mu0 = mu0_test_non_norm, ps=ps_test_non_norm,
X = covariates_test, A = A_test, Y = Y_non_test)
PV_decision_surrogate2 <- aipw_policy_value(policy=surrogate2,
mu0 = mu0_test_non_norm, ps=ps_test_non_norm,
X = covariates_test, A = A_test, Y = Y_non_test)
# Evaluation of constraint values
C_proba_pluc <- aipw_constraint_value(policy=proba_PLUC_test,
nu0 = nu0_test_non_norm, ps=ps_test_non_norm,
X = covariates_test, A = A_test, Xi = Xi_test)
C_proba_pluc0 <- aipw_constraint_value(policy=proba_PLUC0_test,
nu0 = nu0_test_non_norm, ps=ps_test_non_norm,
X = covariates_test, A = A_test, Xi = Xi_test)
C_decision_pluc <- aipw_constraint_value(policy=decision_PLUC_test,
nu0 = nu0_test_non_norm, ps=ps_test_non_norm,
X = covariates_test, A = A_test, Xi = Xi_test)
C_proba_naive <- aipw_constraint_value(policy=proba_Naive_test,
nu0 = nu0_test_non_norm, ps=ps_test_non_norm,
X = covariates_test, A = A_test, Xi = Xi_test)
C_proba_naive0 <- aipw_constraint_value(policy=proba_Naive0_test,
nu0 = nu0_test_non_norm, ps=ps_test_non_norm,
X = covariates_test, A = A_test, Xi = Xi_test)
C_decision_naive <- aipw_constraint_value(policy=decision_Naive_test,
nu0 = nu0_test_non_norm, ps=ps_test_non_norm,
X = covariates_test, A = A_test, Xi = Xi_test)
C_decision_baseline <- aipw_constraint_value(policy=baseline_test,
nu0 = nu0_test_non_norm, ps=ps_test_non_norm,
X = covariates_test, A = A_test, Xi = Xi_test)
C_decision_surrogate1 <- aipw_constraint_value(policy=surrogate1,
nu0 = nu0_test_non_norm, ps=ps_test_non_norm,
X = covariates_test, A = A_test, Xi = Xi_test)
C_decision_surrogate2 <- aipw_constraint_value(policy=surrogate2,
nu0 = nu0_test_non_norm, ps=ps_test_non_norm,
X = covariates_test, A = A_test, Xi = Xi_test)
results <- rbind(PLUC = c(PV_proba_pluc, C_proba_pluc),
PLUC0 = c(PV_proba_pluc0, C_proba_pluc0),
d_PLUC = c(PV_decision_pluc, C_decision_pluc),
Naive = c(PV_proba_naive, C_proba_naive),
Naive0 = c(PV_proba_naive0, C_proba_naive0),
d_Naive = c(PV_decision_naive, C_decision_naive),
baseline = c(PV_decision_baseline, C_decision_baseline),
surrogate1 = c(PV_decision_surrogate1, C_decision_surrogate1),
surrogate2 = c(PV_decision_surrogate2, C_decision_surrogate2))
colnames(results) <- c("AIPW Policy value", "Constraint value","AIPW Constraint value")
print(results)
