decision_Naive_test <- decision_Naive[folds[[3]]]
CATE_Y_test <- mu0_test_non_norm(a=rep(1,nrow(covariates_test)),x=covariates_test) -
mu0_test_non_norm(a=rep(0,nrow(covariates_test)),x=covariates_test)
CATE_Xi_test <- nu0_test_non_norm(a=rep(1,nrow(covariates_test)),x=covariates_test) -
nu0_test_non_norm(a=rep(0,nrow(covariates_test)),x=covariates_test)
surrogate1 <- ifelse(CATE_Y_test>0, 1, 0)
surrogate2 <- ifelse(CATE_Y_test>0, 1, 0) * ifelse(CATE_Xi_test<=alpha, 1, 0)
surrogate2 <- ifelse(CATE_Y_test>0, 1, 0) * ifelse(CATE_Xi_test<=alpha.tolerance, 1, 0)
aipw_policy_value <- function(policy, mu0, ps, X, A, Y){
yA <- mu0(a=A,x=X)
y_policy <- mu0(a=policy,x=X)
corrected <- y_policy + ((A*policy + (1-A)*(1-policy))/(ps(a=A,x=X)))*(Y-yA)
aipw_value <- mean(corrected)
return(aipw_value)
}
aipw_constraint_value <- function(policy, nu0, ps, X, A, Xi){
XiA <- nu0(a=A,x=X)
Xi1 <- nu0(a=rep(1,nrow(X)),x=X)
Xi0 <- nu0(a=rep(0,nrow(X)),x=X)
term <- policy * (Xi1-Xi0) - alpha.tolerance
corrected <- term + ((2*A-1)/(ps(a=A,x=X)))*policy*(Xi-XiA)
aipw_value <- mean(corrected)
return(aipw_value)
}
